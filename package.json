{
  "name": "claude-code-shortcut",
  "version": "1.0.0",
  "description": "Claude Code 命令行快捷工具 - 悬浮置顶、全局热键、智能搜索",
  "main": "code/build/dist-electron/main.js",
  "scripts": {
    "dev": "vite --config code/build/vite.config.ts",
    "build": "node code/build/build.js",
    "preview": "vite preview --config code/build/vite.config.ts",
    "electron:dev": "vite build --config code/build/vite.config.ts && electron ."
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.1.2",
    "koffi": "^2.15.2",
    "sql.js": "^1.10.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.claudecode.shortcut",
    "productName": "Claude Code Shortcut",
    "directories": {
      "output": "release"
    },
    "files": [
      "code/build/dist/**/*",
      "code/build/dist-electron/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/koffi/**/*",
      "data.db"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "extraFiles": [
      {
        "from": "data.db",
        "to": "data.db"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "asar": true
  }
}
